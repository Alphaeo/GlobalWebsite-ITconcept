---
import { useAITranslations } from '../../i18n/utils';
export interface Props { lang: 'en' | 'fr' | 'ko'; }
const { lang } = Astro.props;
const t = useAITranslations(lang);
---
<section id="positioning">
  <span class="section-label reveal">{t('pos.label')}</span>
  <h2 class="section-title reveal" set:html={t('pos.title')} />
  <p class="section-desc reveal">{t('pos.desc')}</p>
  <div class="pos-grid reveal">
    <div class="cap-card">
      <div class="cap-icon">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="3"/></svg>
      </div>
      <div class="cap-title">{t('cap1.title')}</div>
      <div class="cap-desc">{t('cap1.desc')}</div>
    </div>
    <div class="cap-card">
      <div class="cap-icon">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07M8.46 8.46a5 5 0 0 0 0 7.07"/></svg>
      </div>
      <div class="cap-title">{t('cap2.title')}</div>
      <div class="cap-desc">{t('cap2.desc')}</div>
    </div>
    <div class="cap-card">
      <div class="cap-icon">
        <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </div>
      <div class="cap-title">{t('cap3.title')}</div>
      <div class="cap-desc">{t('cap3.desc')}</div>
    </div>
    <div class="cap-card">
      <div class="cap-icon">
        <svg viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/></svg>
      </div>
      <div class="cap-title">{t('cap4.title')}</div>
      <div class="cap-desc">{t('cap4.desc')}</div>
    </div>
  </div>
</section>
