---
import { useAITranslations } from '../../i18n/utils';

export interface Props { lang: 'en' | 'fr' | 'ko'; }
const { lang } = Astro.props;
const t = useAITranslations(lang);
---

<footer>
  <div class="footer-top">
    <div>
      <div class="footer-logo-wrap">
        <a href="#hero" class="footer-logo">
          <img src="/logo.png" alt="IT-CONCEPT" class="logo-img" />
        </a>
        <span class="footer-tagline">Servers, Network, Security &amp; Support<br>AI &amp; Data Practice — Seoul, Korea</span>
      </div>
      <div class="footer-social">
        <a href="https://www.linkedin.com/company/itconcept/" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href="mailto:ai@it-concept.kr" aria-label="Email">
          <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </a>
        <a href="tel:+8225537854" aria-label="Phone">
          <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.61 4.35 2 2 0 0 1 3.58 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.16 6.16l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </a>
      </div>
    </div>

    <div>
      <div class="footer-col-title">{t('footer.nav')}</div>
      <ul class="footer-links">
        <li><a href="#services">{t('nav.services')}</a></li>
        <li><a href="#process">{t('nav.process')}</a></li>
        <li><a href="#pocs">{t('nav.pocs')}</a></li>
        <li><a href="#packages">{t('nav.delivery')}</a></li>
        <li><a href="#team">{t('nav.team')}</a></li>
        <li><a href="#company">{t('nav.company')}</a></li>
        <li><a href="#contact">{t('nav.contact')}</a></li>
      </ul>
    </div>

    <div>
      <div class="footer-col-title">{t('footer.contact')}</div>
      <div class="footer-contact-line">
        <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span>#603 Dangsan Bldg, 147 Yeongdeungpo-ro<br>Seoul 07266, Korea</span>
      </div>
      <div class="footer-contact-line">
        <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <a href="mailto:ai@it-concept.kr">ai@it-concept.kr</a>
      </div>
      <div class="footer-contact-line">
        <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.61 4.35 2 2 0 0 1 3.58 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.16 6.16l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <a href="tel:+8225537854">+82 2-553-7854</a>
      </div>
      <a href="https://calendly.com/it-concept-ai" target="_blank" rel="noopener" class="footer-booking">
        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        {t('nav.booking')}
      </a>
    </div>
  </div>

  <div class="footer-bottom">
    <span class="footer-copy">&copy; 2025 IT-CONCEPT Korea. {t('footer.rights')}</span>
    <div class="footer-legal">
      <a href="/mentions-legales/">{t('footer.privacy')}</a>
      <a href="/cookies/">{t('footer.cookies')}</a>
    </div>
  </div>
</footer>
