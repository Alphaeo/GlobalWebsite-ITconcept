---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';
import { supabase } from '../../lib/supabase';
const lang = 'en';
const t = useTranslations(lang);
const { data: events } = await supabase.from('events').select('id,title_en,title_fr,title_ko,event_date,location,description_en,description_fr,description_ko,registration_url,cover_url').eq('published', true).order('event_date', { ascending: true });
const canonical = 'https://www.it-concept.kr/events/';
const eventsSchema = events?.length ? {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": events.map((ev, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Event",
      "name": ev.title_en || ev.title_fr || ev.title_ko,
      "startDate": ev.event_date,
      "location": { "@type": "Place", "name": ev.location || "Seoul" },
      "description": ev.description_en || ev.description_fr || ev.description_ko || "",
      "organizer": { "@type": "Organization", "name": "IT-CONCEPT", "url": "https://www.it-concept.kr" },
      ...(ev.registration_url ? { "url": ev.registration_url } : {})
    }
  }))
} : null;
---
<BaseLayout lang={lang} title="Events — IT-CONCEPT" canonical={canonical}>
  {eventsSchema && <script type="application/ld+json" set:html={JSON.stringify(eventsSchema)} />}
  <section style="padding-top: calc(var(--nav-h) + 60px)">
    <span class="section-label reveal">{t('events.label')}</span>
    <h1 class="section-title reveal">{t('events.title')}</h1>
    <p class="section-desc reveal">{t('events.desc')}</p>
    <div class="cards-grid">
      {!events?.length ? (
        <div class="empty-state">
          <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <p>{t('events.empty')}</p>
        </div>
      ) : events.map(ev => (
        <div class="content-card reveal">
          {ev.cover_url
            ? <img src={ev.cover_url} alt={ev.title_en || ''} class="card-cover" loading="lazy" />
            : <div class="card-cover-placeholder"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
          }
          <div class="card-body">
            <div class="card-tags"><span class="card-tag">{new Date(ev.event_date).toLocaleDateString('en', { month: 'short', day: 'numeric', year: 'numeric' })}</span></div>
            <h2 class="card-title">{ev.title_en || ev.title_fr || ev.title_ko}</h2>
            {(ev.description_en || ev.description_fr || ev.description_ko) && <p class="card-excerpt">{ev.description_en || ev.description_fr || ev.description_ko}</p>}
            <div class="card-meta">
              <span>{t('events.location')}: {ev.location}</span>
            </div>
            {ev.registration_url && <a href={ev.registration_url} target="_blank" rel="noopener" class="btn-primary" style="font-size:0.85rem;padding:10px 18px">{t('events.register')}</a>}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
