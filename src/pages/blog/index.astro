---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';
import { supabase } from '../../lib/supabase';
const lang = 'en';
const t = useTranslations(lang);
const { data: articles } = await supabase.from('articles').select('id,slug,title_en,excerpt_en,author,tags,cover_url,published_at').eq('published', true).order('published_at', { ascending: false });
---
<BaseLayout lang={lang} title={`Blog — IT-CONCEPT`}>
  <section style="padding-top: calc(var(--nav-h) + 60px)">
    <span class="section-label reveal">{t('blog.label')}</span>
    <h1 class="section-title reveal">{t('blog.title')}</h1>
    <p class="section-desc reveal">{t('blog.desc')}</p>
    <div class="cards-grid">
      {!articles?.length ? (
        <div class="empty-state">
          <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <p>{t('blog.empty')}</p>
        </div>
      ) : articles.map(a => (
        <article class="content-card reveal">
          {a.cover_url ? <img src={a.cover_url} alt={a.title_en} class="card-cover" loading="lazy" /> : <div class="card-cover-placeholder"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg></div>}
          <div class="card-body">
            {a.tags?.length ? <div class="card-tags">{a.tags.slice(0,2).map((tag: string) => <span class="card-tag">{tag}</span>)}</div> : null}
            <h2 class="card-title">{a.title_en}</h2>
            {a.excerpt_en && <p class="card-excerpt">{a.excerpt_en}</p>}
            <div class="card-meta">
              {a.author && <span>{a.author}</span>}
              {a.published_at && <span>{new Date(a.published_at).toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' })}</span>}
            </div>
            <a href={`/blog/${a.slug}/`} class="card-link">{t('blog.readmore')} →</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
