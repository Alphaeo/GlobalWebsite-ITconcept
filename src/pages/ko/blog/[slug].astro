---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { supabase } from '../../../lib/supabase';
import { useTranslations } from '../../../i18n/utils';
const lang = 'ko';
const t = useTranslations(lang);
const { slug } = Astro.params;
const { data: article } = await supabase
  .from('articles')
  .select('*')
  .eq('slug', slug)
  .eq('published', true)
  .single();
if (!article) return Astro.redirect('/ko/blog');
---
<BaseLayout lang={lang}>
  <article class="article-page">
    {article.cover_url && <img src={article.cover_url} alt={article.title_ko || article.title_en} class="article-cover" />}
    <div class="article-meta">
      {article.tags?.length && <div class="blog-tags">{article.tags.map((tag: string) => <span class="blog-tag">{tag}</span>)}</div>}
      <time>{new Date(article.published_at).toLocaleDateString('ko')}</time>
    </div>
    <h1>{article.title_ko || article.title_en}</h1>
    <div class="article-body" set:html={article.content_ko || article.content_en} />
    <a href="/ko/blog" class="btn-outline" style="margin-top:40px;display:inline-block">← {t('blog.back')}</a>
  </article>
</BaseLayout>
