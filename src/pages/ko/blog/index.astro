---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { supabase } from '../../../lib/supabase';
import { useTranslations } from '../../../i18n/utils';
const lang = 'ko';
const t = useTranslations(lang);
const { data: articles } = await supabase
  .from('articles')
  .select('id,slug,title_ko,title_en,cover_url,published_at,tags')
  .eq('published', true)
  .order('published_at', { ascending: false });
---
<BaseLayout lang={lang}>
  <section id="blog">
    <span class="section-label">{t('blog.label')}</span>
    <h1 class="section-title">{t('blog.title')}</h1>
    <p class="section-desc">{t('blog.desc')}</p>
    <div class="blog-grid">
      {articles?.length ? articles.map(a => (
        <a href={`/ko/blog/${a.slug}`} class="blog-card">
          {a.cover_url && <img src={a.cover_url} alt={a.title_ko || a.title_en} loading="lazy" />}
          <div class="blog-card-body">
            {a.tags?.length && <div class="blog-tags">{a.tags.map((tag: string) => <span class="blog-tag">{tag}</span>)}</div>}
            <h2>{a.title_ko || a.title_en}</h2>
            <time>{new Date(a.published_at).toLocaleDateString('ko')}</time>
          </div>
        </a>
      )) : <p style="color:var(--text-muted);grid-column:1/-1">{t('blog.empty')}</p>}
    </div>
  </section>
</BaseLayout>
