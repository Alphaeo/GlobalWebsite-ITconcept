---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { supabase } from '../../../lib/supabase';
import { useTranslations } from '../../../i18n/utils';
const lang = 'ko';
const t = useTranslations(lang);
const { data: events } = await supabase
  .from('events')
  .select('id,title_ko,title_en,title_fr,event_date,location,description_ko,description_en,description_fr,registration_url,cover_url')
  .eq('published', true)
  .order('event_date', { ascending: true });
const canonical = 'https://www.it-concept.kr/ko/events/';
const eventsSchema = events?.length ? {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": events.map((ev, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Event",
      "name": ev.title_ko || ev.title_en || ev.title_fr,
      "startDate": ev.event_date,
      "location": { "@type": "Place", "name": ev.location || "서울" },
      "description": ev.description_ko || ev.description_en || ev.description_fr || "",
      "organizer": { "@type": "Organization", "name": "IT-CONCEPT", "url": "https://www.it-concept.kr" },
      ...(ev.registration_url ? { "url": ev.registration_url } : {})
    }
  }))
} : null;
---
<BaseLayout lang={lang} canonical={canonical}>
  {eventsSchema && <script type="application/ld+json" set:html={JSON.stringify(eventsSchema)} />}
  <section id="events">
    <span class="section-label">{t('events.label')}</span>
    <h1 class="section-title">{t('events.title')}</h1>
    <p class="section-desc">{t('events.desc')}</p>
    <div class="cards-grid">
      {!events?.length ? (
        <div class="empty-state">
          <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <p>{t('events.empty')}</p>
        </div>
      ) : events.map(ev => (
        <div class="content-card reveal">
          {ev.cover_url
            ? <img src={ev.cover_url} alt={ev.title_ko || ev.title_en || ''} class="card-cover" loading="lazy" />
            : <div class="card-cover-placeholder"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
          }
          <div class="card-body">
            <div class="card-tags"><span class="card-tag">{new Date(ev.event_date).toLocaleDateString('ko', { month: 'short', day: 'numeric', year: 'numeric' })}</span></div>
            <h2 class="card-title">{ev.title_ko || ev.title_en || ev.title_fr}</h2>
            {(ev.description_ko || ev.description_en || ev.description_fr) && <p class="card-excerpt">{ev.description_ko || ev.description_en || ev.description_fr}</p>}
            <div class="card-meta"><span>{t('events.location')}: {ev.location}</span></div>
            {ev.registration_url && <a href={ev.registration_url} target="_blank" rel="noopener" class="btn-primary" style="font-size:0.85rem;padding:10px 18px;margin-top:auto">{t('events.register')}</a>}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
