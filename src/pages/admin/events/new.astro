---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase';
const sb = createSupabaseServerClient({ request: Astro.request, cookies: Astro.cookies });
const { data: { session } } = await sb.auth.getSession();
if (!session) return Astro.redirect('/admin/');
let error = '';
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const { error: err } = await sb.from('events').insert({
    published: form.get('published') === 'on',
    event_date: form.get('event_date'),
    location: form.get('location'),
    registration_url: form.get('registration_url') || null,
    title_en: form.get('title_en') || null, title_fr: form.get('title_fr') || null, title_ko: form.get('title_ko') || null,
    description_en: form.get('description_en') || null, description_fr: form.get('description_fr') || null, description_ko: form.get('description_ko') || null,
  });
  if (err) error = err.message;
  else return Astro.redirect('/admin/events');
}
---
<AdminLayout title="New Event" active="events">
  <div class="admin-header"><h1>New Event</h1><a href="/admin/events" class="btn-sm btn-sm-outline">← Back</a></div>
  {error && <div style="background:#fee2e2;color:#ef4444;padding:12px 16px;border-radius:8px;margin-bottom:20px">{error}</div>}
  <form method="POST">
    <div class="admin-card">
      <div class="form-row">
        <div class="form-group"><label>Date & Time*</label><input type="datetime-local" name="event_date" required /></div>
        <div class="form-group"><label>Location*</label><input type="text" name="location" placeholder="Seoul, Korea" required /></div>
      </div>
      <div class="form-group"><label>Registration URL</label><input type="url" name="registration_url" placeholder="https://..." /></div>
    </div>
    <div class="admin-card">
      <h3 style="font-family:var(--font-display);font-weight:700;margin-bottom:20px;font-size:1rem">🇬🇧 English</h3>
      <div class="form-group"><label>Title (EN)</label><input type="text" name="title_en" /></div>
      <div class="form-group"><label>Description (EN)</label><textarea name="description_en" rows="4"></textarea></div>
    </div>
    <div class="admin-card">
      <h3 style="font-family:var(--font-display);font-weight:700;margin-bottom:20px;font-size:1rem">🇫🇷 Français</h3>
      <div class="form-group"><label>Titre (FR)</label><input type="text" name="title_fr" /></div>
      <div class="form-group"><label>Description (FR)</label><textarea name="description_fr" rows="4"></textarea></div>
    </div>
    <div class="admin-card">
      <h3 style="font-family:var(--font-display);font-weight:700;margin-bottom:20px;font-size:1rem">🇰🇷 한국어</h3>
      <div class="form-group"><label>제목 (KO)</label><input type="text" name="title_ko" /></div>
      <div class="form-group"><label>설명 (KO)</label><textarea name="description_ko" rows="4"></textarea></div>
    </div>
    <div class="admin-card">
      <div class="form-group" style="flex-direction:row;align-items:center;gap:10px;margin-bottom:0">
        <input type="checkbox" name="published" id="published" style="width:auto" />
        <label for="published" style="margin-bottom:0">Publish immediately</label>
      </div>
    </div>
    <div style="display:flex;gap:12px">
      <button type="submit" class="btn-sm btn-sm-primary" style="padding:10px 24px">Save event</button>
      <a href="/admin/events" class="btn-sm btn-sm-outline" style="padding:10px 24px">Cancel</a>
    </div>
  </form>
</AdminLayout>
