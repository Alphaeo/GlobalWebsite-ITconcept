---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createSupabaseServerClient, supabase } from '../../../lib/supabase';
const sb = createSupabaseServerClient(Astro.cookies);
const { data: { session } } = await sb.auth.getSession();
if (!session) return Astro.redirect('/admin/');
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const id = form.get('delete_id') as string;
  if (id) await supabase.from('events').delete().eq('id', id);
}
const { data: events } = await supabase.from('events').select('id,title_en,event_date,location,published').order('event_date', { ascending: true });
---
<AdminLayout title="Events" active="events">
  <div class="admin-header">
    <h1>Events</h1>
    <a href="/admin/events/new" class="btn-sm btn-sm-primary">+ New event</a>
  </div>
  <div class="admin-card">
    <table class="admin-table">
      <thead><tr><th>Title</th><th>Date</th><th>Location</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody>
        {events?.length ? events.map(ev => (
          <tr>
            <td style="font-weight:600">{ev.title_en || '(no title)'}</td>
            <td>{new Date(ev.event_date).toLocaleDateString('en')}</td>
            <td>{ev.location}</td>
            <td><span class:list={['badge', ev.published ? 'badge-green' : 'badge-grey']}>{ev.published ? 'Published' : 'Draft'}</span></td>
            <td style="display:flex;gap:8px">
              <a href={`/admin/events/${ev.id}`} class="btn-sm btn-sm-outline">Edit</a>
              <form method="POST" onsubmit="return confirm('Delete this event?')">
                <input type="hidden" name="delete_id" value={ev.id} />
                <button type="submit" class="btn-sm btn-sm-danger">Delete</button>
              </form>
            </td>
          </tr>
        )) : <tr><td colspan="5" style="text-align:center;color:var(--text-muted);padding:40px">No events yet.</td></tr>}
      </tbody>
    </table>
  </div>
</AdminLayout>
