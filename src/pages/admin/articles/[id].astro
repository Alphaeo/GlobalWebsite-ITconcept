---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase';
const sb = createSupabaseServerClient({ request: Astro.request, cookies: Astro.cookies });
const { data: { session } } = await sb.auth.getSession();
if (!session) return Astro.redirect('/admin/');
const { id } = Astro.params;
let error = '';
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const tags = (form.get('tags') as string).split(',').map(t => t.trim()).filter(Boolean);
  const published = form.get('published') === 'on';
  const { error: err } = await sb.from('articles').update({
    tags, published,
    title_en: form.get('title_en') || null, title_fr: form.get('title_fr') || null, title_ko: form.get('title_ko') || null,
    excerpt_en: form.get('excerpt_en') || null, excerpt_fr: form.get('excerpt_fr') || null, excerpt_ko: form.get('excerpt_ko') || null,
    content_en: form.get('content_en') || null, content_fr: form.get('content_fr') || null, content_ko: form.get('content_ko') || null,
    author: form.get('author') || null,
    cover_url: form.get('cover_url') || null,
    published_at: published ? new Date().toISOString() : null,
  }).eq('id', id);
  if (err) error = err.message;
  else return Astro.redirect('/admin/articles');
}
const { data: a } = await sb.from('articles').select('*').eq('id', id).single();
if (!a) return Astro.redirect('/admin/articles');
---
<AdminLayout title="Edit Article" active="articles">
  <div class="admin-header">
    <h1>Edit Article</h1>
    <a href="/admin/articles" class="btn-sm btn-sm-outline">← Back</a>
  </div>
  {error && <div style="background:#fee2e2;color:#ef4444;padding:12px 16px;border-radius:8px;margin-bottom:20px">{error}</div>}
  <form method="POST">
    <div class="admin-card">
      <h3 style="font-family:var(--font-display);font-weight:700;margin-bottom:20px;font-size:1rem">🇬🇧 English</h3>
      <div class="form-group"><label>Title (EN)</label><input type="text" name="title_en" value={a.title_en ?? ''} /></div>
      <div class="form-group"><label>Excerpt (EN)</label><textarea name="excerpt_en" rows="2">{a.excerpt_en}</textarea></div>
      <div class="form-group"><label>Content (EN) — HTML supported</label><textarea name="content_en" rows="10">{a.content_en}</textarea></div>
    </div>
    <div class="admin-card">
      <h3 style="font-family:var(--font-display);font-weight:700;margin-bottom:20px;font-size:1rem">🇫🇷 Français</h3>
      <div class="form-group"><label>Titre (FR)</label><input type="text" name="title_fr" value={a.title_fr ?? ''} /></div>
      <div class="form-group"><label>Extrait (FR)</label><textarea name="excerpt_fr" rows="2">{a.excerpt_fr}</textarea></div>
      <div class="form-group"><label>Contenu (FR)</label><textarea name="content_fr" rows="10">{a.content_fr}</textarea></div>
    </div>
    <div class="admin-card">
      <h3 style="font-family:var(--font-display);font-weight:700;margin-bottom:20px;font-size:1rem">🇰🇷 한국어</h3>
      <div class="form-group"><label>제목 (KO)</label><input type="text" name="title_ko" value={a.title_ko ?? ''} /></div>
      <div class="form-group"><label>발췌 (KO)</label><textarea name="excerpt_ko" rows="2">{a.excerpt_ko}</textarea></div>
      <div class="form-group"><label>내용 (KO)</label><textarea name="content_ko" rows="10">{a.content_ko}</textarea></div>
    </div>
    <div class="admin-card">
      <div class="form-row">
        <div class="form-group"><label>Author</label><input type="text" name="author" value={a.author ?? ''} /></div>
        <div class="form-group"><label>Tags (comma-separated)</label><input type="text" name="tags" value={a.tags?.join(', ') ?? ''} /></div>
      </div>
      <div class="form-group"><label>Cover image URL</label><input type="url" name="cover_url" value={a.cover_url ?? ''} placeholder="https://..." /></div>
      <div class="form-group" style="flex-direction:row;align-items:center;gap:10px;margin-bottom:0">
        <input type="checkbox" name="published" id="published" checked={a.published} style="width:auto" />
        <label for="published" style="margin-bottom:0">Published</label>
      </div>
    </div>
    <div style="display:flex;gap:12px">
      <button type="submit" class="btn-sm btn-sm-primary" style="padding:10px 24px">Save changes</button>
      <a href="/admin/articles" class="btn-sm btn-sm-outline" style="padding:10px 24px">Cancel</a>
    </div>
  </form>
</AdminLayout>
