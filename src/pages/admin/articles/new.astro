---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase';
const sb = createSupabaseServerClient({ request: Astro.request, cookies: Astro.cookies });
const { data: { session } } = await sb.auth.getSession();
if (!session) return Astro.redirect('/admin/');
let error = '';
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const titleEn = (form.get('title_en') as string) || (form.get('title_fr') as string) || (form.get('title_ko') as string) || 'untitled';
  const slug = titleEn.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  const tags = (form.get('tags') as string).split(',').map(t => t.trim()).filter(Boolean);
  const published = form.get('published') === 'on';
  const { error: err } = await sb.from('articles').insert({
    slug, tags, published,
    title_en: form.get('title_en') || null, title_fr: form.get('title_fr') || null, title_ko: form.get('title_ko') || null,
    excerpt_en: form.get('excerpt_en') || null, excerpt_fr: form.get('excerpt_fr') || null, excerpt_ko: form.get('excerpt_ko') || null,
    content_en: form.get('content_en') || null, content_fr: form.get('content_fr') || null, content_ko: form.get('content_ko') || null,
    author: form.get('author') || null,
    published_at: published ? new Date().toISOString() : null,
  });
  if (err) error = err.message;
  else return Astro.redirect('/admin/articles');
}
---
<AdminLayout title="New Article" active="articles">
  <div class="admin-header">
    <h1>New Article</h1>
    <a href="/admin/articles" class="btn-sm btn-sm-outline">← Back</a>
  </div>
  {error && <div style="background:#fee2e2;color:#ef4444;padding:12px 16px;border-radius:8px;margin-bottom:20px">{error}</div>}
  <form method="POST">
    <div class="admin-card">
      <h3 style="font-family:var(--font-display);font-weight:700;margin-bottom:20px;font-size:1rem">🇬🇧 English</h3>
      <div class="form-group"><label>Title (EN)</label><input type="text" name="title_en" /></div>
      <div class="form-group"><label>Excerpt (EN)</label><textarea name="excerpt_en" rows="2"></textarea></div>
      <div class="form-group"><label>Content (EN) — HTML supported</label><textarea name="content_en" rows="10"></textarea></div>
    </div>
    <div class="admin-card">
      <h3 style="font-family:var(--font-display);font-weight:700;margin-bottom:20px;font-size:1rem">🇫🇷 Français</h3>
      <div class="form-group"><label>Titre (FR)</label><input type="text" name="title_fr" /></div>
      <div class="form-group"><label>Extrait (FR)</label><textarea name="excerpt_fr" rows="2"></textarea></div>
      <div class="form-group"><label>Contenu (FR)</label><textarea name="content_fr" rows="10"></textarea></div>
    </div>
    <div class="admin-card">
      <h3 style="font-family:var(--font-display);font-weight:700;margin-bottom:20px;font-size:1rem">🇰🇷 한국어</h3>
      <div class="form-group"><label>제목 (KO)</label><input type="text" name="title_ko" /></div>
      <div class="form-group"><label>발췌 (KO)</label><textarea name="excerpt_ko" rows="2"></textarea></div>
      <div class="form-group"><label>내용 (KO)</label><textarea name="content_ko" rows="10"></textarea></div>
    </div>
    <div class="admin-card">
      <div class="form-row">
        <div class="form-group"><label>Author</label><input type="text" name="author" placeholder="Jean Dupont" /></div>
        <div class="form-group"><label>Tags (comma-separated)</label><input type="text" name="tags" placeholder="Security, Network, Microsoft" /></div>
      </div>
      <div class="form-group" style="flex-direction:row;align-items:center;gap:10px;margin-bottom:0">
        <input type="checkbox" name="published" id="published" style="width:auto" />
        <label for="published" style="margin-bottom:0">Publish immediately</label>
      </div>
    </div>
    <div style="display:flex;gap:12px">
      <button type="submit" class="btn-sm btn-sm-primary" style="padding:10px 24px;font-size:0.95rem">Save article</button>
      <a href="/admin/articles" class="btn-sm btn-sm-outline" style="padding:10px 24px">Cancel</a>
    </div>
  </form>
</AdminLayout>
