---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createSupabaseServerClient, supabase } from '../../../lib/supabase';
const sb = createSupabaseServerClient(Astro.cookies);
const { data: { session } } = await sb.auth.getSession();
if (!session) return Astro.redirect('/admin/');
let error = '';
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const { error: err } = await supabase.from('job_offers').insert({
    published: form.get('published') === 'on',
    contract_type: form.get('contract_type'),
    location: form.get('location'),
    deadline: form.get('deadline') || null,
    title_en: form.get('title_en'), title_fr: form.get('title_fr'), title_ko: form.get('title_ko'),
    description_en: form.get('description_en'), description_fr: form.get('description_fr'), description_ko: form.get('description_ko'),
  });
  if (err) error = err.message;
  else return Astro.redirect('/admin/jobs');
}
---
<AdminLayout title="New Job Offer" active="jobs">
  <div class="admin-header"><h1>New Job Offer</h1><a href="/admin/jobs" class="btn-sm btn-sm-outline">← Back</a></div>
  {error && <div style="background:#fee2e2;color:#ef4444;padding:12px 16px;border-radius:8px;margin-bottom:20px">{error}</div>}
  <form method="POST">
    <div class="admin-card">
      <div class="form-row">
        <div class="form-group">
          <label>Contract Type*</label>
          <select name="contract_type" required>
            <option value="CDI">CDI</option>
            <option value="CDD">CDD</option>
            <option value="Stage">Stage</option>
            <option value="Freelance">Freelance</option>
            <option value="Full-time">Full-time</option>
            <option value="Part-time">Part-time</option>
          </select>
        </div>
        <div class="form-group"><label>Location*</label><input type="text" name="location" value="Seoul, Korea" required /></div>
      </div>
      <div class="form-group"><label>Application deadline</label><input type="date" name="deadline" /></div>
    </div>
    <div class="admin-card">
      <h3 style="font-family:var(--font-display);font-weight:700;margin-bottom:20px;font-size:1rem">🇬🇧 English</h3>
      <div class="form-group"><label>Job Title (EN)*</label><input type="text" name="title_en" placeholder="IT Support Engineer" required /></div>
      <div class="form-group"><label>Description (EN)</label><textarea name="description_en" rows="6" placeholder="Role, responsibilities, requirements..."></textarea></div>
    </div>
    <div class="admin-card">
      <h3 style="font-family:var(--font-display);font-weight:700;margin-bottom:20px;font-size:1rem">🇫🇷 Français</h3>
      <div class="form-group"><label>Intitulé du poste (FR)</label><input type="text" name="title_fr" /></div>
      <div class="form-group"><label>Description (FR)</label><textarea name="description_fr" rows="6"></textarea></div>
    </div>
    <div class="admin-card">
      <div class="form-group" style="flex-direction:row;align-items:center;gap:10px;margin-bottom:0">
        <input type="checkbox" name="published" id="published" style="width:auto" />
        <label for="published" style="margin-bottom:0">Publish immediately</label>
      </div>
    </div>
    <div style="display:flex;gap:12px">
      <button type="submit" class="btn-sm btn-sm-primary" style="padding:10px 24px">Save offer</button>
      <a href="/admin/jobs" class="btn-sm btn-sm-outline" style="padding:10px 24px">Cancel</a>
    </div>
  </form>
</AdminLayout>
