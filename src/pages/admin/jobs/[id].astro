---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createSupabaseServerClient } from '../../../lib/supabase';
const sb = createSupabaseServerClient({ request: Astro.request, cookies: Astro.cookies });
const { data: { session } } = await sb.auth.getSession();
if (!session) return Astro.redirect('/admin/');
const { id } = Astro.params;
let error = '';
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const { error: err } = await sb.from('job_offers').update({
    published: form.get('published') === 'on',
    contract_type: form.get('contract_type'),
    location: form.get('location'),
    deadline: form.get('deadline') || null,
    title_en: form.get('title_en') || null, title_fr: form.get('title_fr') || null, title_ko: form.get('title_ko') || null,
    description_en: form.get('description_en') || null, description_fr: form.get('description_fr') || null, description_ko: form.get('description_ko') || null,
  }).eq('id', id);
  if (err) error = err.message;
  else return Astro.redirect('/admin/jobs');
}
const { data: job } = await sb.from('job_offers').select('*').eq('id', id).single();
if (!job) return Astro.redirect('/admin/jobs');
const deadlineValue = job.deadline ? new Date(job.deadline).toISOString().slice(0, 10) : '';
---
<AdminLayout title="Edit Job Offer" active="jobs">
  <div class="admin-header"><h1>Edit Job Offer</h1><a href="/admin/jobs" class="btn-sm btn-sm-outline">← Back</a></div>
  {error && <div style="background:#fee2e2;color:#ef4444;padding:12px 16px;border-radius:8px;margin-bottom:20px">{error}</div>}
  <form method="POST">
    <div class="admin-card">
      <div class="form-row">
        <div class="form-group">
          <label>Contract Type*</label>
          <select name="contract_type" required>
            {['CDI','CDD','Stage','Freelance','Full-time','Part-time'].map(t => (
              <option value={t} selected={job.contract_type === t}>{t}</option>
            ))}
          </select>
        </div>
        <div class="form-group"><label>Location*</label><input type="text" name="location" value={job.location} required /></div>
      </div>
      <div class="form-group"><label>Application deadline</label><input type="date" name="deadline" value={deadlineValue} /></div>
    </div>
    <div class="admin-card">
      <h3 style="font-family:var(--font-display);font-weight:700;margin-bottom:20px;font-size:1rem">🇬🇧 English</h3>
      <div class="form-group"><label>Job Title (EN)</label><input type="text" name="title_en" value={job.title_en ?? ''} /></div>
      <div class="form-group"><label>Description (EN)</label><textarea name="description_en" rows="6">{job.description_en}</textarea></div>
    </div>
    <div class="admin-card">
      <h3 style="font-family:var(--font-display);font-weight:700;margin-bottom:20px;font-size:1rem">🇫🇷 Français</h3>
      <div class="form-group"><label>Intitulé du poste (FR)</label><input type="text" name="title_fr" value={job.title_fr ?? ''} /></div>
      <div class="form-group"><label>Description (FR)</label><textarea name="description_fr" rows="6">{job.description_fr}</textarea></div>
    </div>
    <div class="admin-card">
      <h3 style="font-family:var(--font-display);font-weight:700;margin-bottom:20px;font-size:1rem">🇰🇷 한국어</h3>
      <div class="form-group"><label>직책명 (KO)</label><input type="text" name="title_ko" value={job.title_ko ?? ''} /></div>
      <div class="form-group"><label>직무 설명 (KO)</label><textarea name="description_ko" rows="6">{job.description_ko}</textarea></div>
    </div>
    <div class="admin-card">
      <div class="form-group" style="flex-direction:row;align-items:center;gap:10px;margin-bottom:0">
        <input type="checkbox" name="published" id="published" checked={job.published} style="width:auto" />
        <label for="published" style="margin-bottom:0">Published</label>
      </div>
    </div>
    <div style="display:flex;gap:12px">
      <button type="submit" class="btn-sm btn-sm-primary" style="padding:10px 24px">Save changes</button>
      <a href="/admin/jobs" class="btn-sm btn-sm-outline" style="padding:10px 24px">Cancel</a>
    </div>
  </form>
</AdminLayout>
