---
import '../styles/global.css';
export interface Props { title?: string; active?: string; }
const { title = 'Admin', active = '' } = Astro.props;
const navItems = [
  { href: '/admin/dashboard', label: 'Dashboard', icon: 'grid', key: 'dashboard' },
  { href: '/admin/articles', label: 'Articles', icon: 'file-text', key: 'articles' },
  { href: '/admin/events', label: 'Events', icon: 'calendar', key: 'events' },
  { href: '/admin/jobs', label: 'Job Offers', icon: 'briefcase', key: 'jobs' },
];
const icons: Record<string, string> = {
  grid: '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>',
  'file-text': '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>',
  calendar: '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>',
  briefcase: '<rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>',
  logout: '<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>',
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — IT-CONCEPT Admin</title>
  <link rel="icon" type="image/png" href="/favicon-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; } html, body { height: 100%; } body { font-family: 'Source Sans 3', sans-serif; }</style>
</head>
<body>
  <div class="admin-layout">
    <aside class="admin-sidebar">
      <div class="admin-sidebar-logo">
        <a href="/"><img src="/logo.png" alt="IT-CONCEPT" /></a>
      </div>
      <div class="admin-nav-section">Content</div>
      {navItems.map(item => (
        <a href={item.href} class:list={['admin-nav-link', { active: active === item.key }]}>
          <svg viewBox="0 0 24 24" set:html={icons[item.icon]} />
          {item.label}
        </a>
      ))}
      <div style="margin-top: auto; padding-top: 32px; border-top: 1px solid rgba(255,255,255,0.08); margin-top: 32px;">
        <a href="/admin/logout" class="admin-nav-link">
          <svg viewBox="0 0 24 24" set:html={icons.logout} />
          Sign out
        </a>
        <a href="/" class="admin-nav-link" style="font-size:0.82rem; color: rgba(255,255,255,0.35)">
          ← Back to website
        </a>
      </div>
    </aside>
    <main class="admin-main">
      <slot />
    </main>
  </div>
</body>
</html>
