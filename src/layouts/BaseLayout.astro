---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import { ClientRouter } from 'astro:transitions';

export interface Props { lang: Lang; title?: string; desc?: string; canonical?: string; }
const { lang, title, desc, canonical: canonicalProp } = Astro.props;
const t = useTranslations(lang);
const site = 'https://www.it-concept.kr';
const canonical = canonicalProp ?? (lang === 'fr' ? `${site}/fr/` : lang === 'ko' ? `${site}/ko/` : `${site}/`);
const ogLocale = lang === 'fr' ? 'fr_FR' : lang === 'ko' ? 'ko_KR' : 'en_US';
const orgDesc = lang === 'fr'
  ? "IT consulting et outsourcing à Séoul — Infrastructure, réseau, sécurité, développement et hébergement."
  : lang === 'ko'
  ? "서울 IT 컨설팅 및 아웃소싱 — 인프라, 네트워크, 보안, 개발, 호스팅."
  : "IT consulting and outsourcing in Seoul. Infrastructure, network, security, development and hosting.";
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title ?? t('meta.title')}</title>
  <meta name="description" content={desc ?? t('meta.desc')} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="en" href={`${site}/`} />
  <link rel="alternate" hreflang="fr" href={`${site}/fr/`} />
  <link rel="alternate" hreflang="ko" href={`${site}/ko/`} />
  <link rel="alternate" hreflang="x-default" href={`${site}/`} />
  <link rel="icon" type="image/png" href="/favicon-icon.png" />
  <link rel="apple-touch-icon" href="/favicon-icon.png" />
  <meta name="theme-color" content="#E53935" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title ?? t('meta.title')} />
  <meta property="og:description" content={desc ?? t('meta.desc')} />
  <meta property="og:image" content={`${site}/logo.png`} />
  <meta property="og:site_name" content="IT-CONCEPT" />
  <meta property="og:locale" content={ogLocale} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title ?? t('meta.title')} />
  <meta name="twitter:description" content={desc ?? t('meta.desc')} />
  <meta name="twitter:image" content={`${site}/logo.png`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <ClientRouter />
  <style>
    @keyframes vt-slide-out {
      from { opacity: 1; transform: translateY(0); }
      to   { opacity: 0; transform: translateY(-10px); }
    }
    @keyframes vt-slide-in {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    ::view-transition-old(root) {
      animation: 260ms cubic-bezier(0.4, 0, 1, 1) vt-slide-out both;
    }
    ::view-transition-new(root) {
      animation: 380ms cubic-bezier(0.16, 1, 0.3, 1) 60ms vt-slide-in both;
    }
  </style>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "IT-CONCEPT",
    "url": site,
    "logo": `${site}/logo.png`,
    "email": "info@it-concept.kr",
    "telephone": "+82-2-553-7854",
    "address": { "@type": "PostalAddress", "streetAddress": "#603 Dangsan Bldg, 147 Yeongdeungpo-ro", "addressLocality": "Seoul", "postalCode": "07266", "addressCountry": "KR" },
    "description": orgDesc
  })} />
</head>
<body>
  <Nav lang={lang} />
  <slot />
  <Footer lang={lang} />
  <CookieBanner lang={lang} />
  <script>
    // Redirect Supabase recovery tokens to the reset-password page
    if (window.location.hash.includes('type=recovery')) {
      window.location.href = '/admin/reset-password' + window.location.hash;
    }
  </script>
  <script>
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e, i) => { if (e.isIntersecting) setTimeout(() => e.target.classList.add('visible'), i * 80); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
    function toggleMobileNav() { document.getElementById('mobileNav')?.classList.toggle('open'); }
    (window as any).toggleMobileNav = toggleMobileNav;
    function dismissCookies(v: boolean) {
      localStorage.setItem('cookie_consent', v ? 'accepted' : 'declined');
      document.getElementById('cookie-banner')?.classList.remove('visible');
    }
    (window as any).dismissCookies = dismissCookies;
    if (!localStorage.getItem('cookie_consent')) {
      setTimeout(() => document.getElementById('cookie-banner')?.classList.add('visible'), 1500);
    }
  </script>
</body>
</html>
